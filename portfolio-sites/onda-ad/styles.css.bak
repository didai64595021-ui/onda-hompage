/* ================================================================
   ONDA AD — SaaS Landing + Dashboard Styles
   네이버 검색광고 올인원 AI 관리
   ================================================================ */

/* === 전역 리셋 === */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { overflow-x: hidden; scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
body {
  font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #0a0a0a;
  color: #e0e0e0;
  word-break: keep-all;
  overflow-wrap: break-word;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  line-height: 1.7;
  font-size: 16px;
}
img, video, svg { max-width: 100%; height: auto; display: block; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; background: none; font: inherit; }
input, select, textarea { font-size: 16px; font: inherit; }
ul, ol { list-style: none; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* === CSS Variables === */
:root {
  --bg-primary: #0a0a0a;
  --bg-card: #111111;
  --bg-elevated: #161616;
  --bg-sidebar: #0e0e0e;
  --border: #1e1e1e;
  --border-hover: #2a2a2a;
  --text-primary: #ffffff;
  --text-secondary: #a0a0a0;
  --text-tertiary: #666666;
  --naver-green: #03C75A;
  --naver-green-hover: #02b050;
  --naver-green-glow: rgba(3, 199, 90, 0.2);
  --kakao-yellow: #FEE500;
  --kakao-text: #191919;
  --danger: #ff4444;
  --warning: #ffaa00;
  --success: #00c853;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --fs-display: clamp(2.5rem, 5vw, 4.5rem);
  --fs-h1: clamp(2rem, 4vw, 3.5rem);
  --fs-h2: clamp(1.5rem, 3vw, 2.5rem);
  --fs-h3: clamp(1.25rem, 2vw, 1.5rem);
  --fs-body: clamp(0.9375rem, 1.2vw, 1.0625rem);
  --fs-small: clamp(0.8125rem, 1vw, 0.875rem);
  --space-section: clamp(48px, 8vw, 100px);
}

/* === Utility === */
.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 40px);
}
.container-wide {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 40px);
}
.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); border: 0;
}

/* === Fade-in Animation === */
.fade-in, .fade-in-left, .fade-in-right, .fade-in-scale {
  opacity: 1;
  transform: none;
  transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
}
.js-scroll-reveal .fade-in:not(.revealed) {
  opacity: 0; transform: translateY(30px);
}
.js-scroll-reveal .fade-in-left:not(.revealed) {
  opacity: 0; transform: translateX(-40px);
}
.js-scroll-reveal .fade-in-right:not(.revealed) {
  opacity: 0; transform: translateX(40px);
}
.js-scroll-reveal .fade-in-scale:not(.revealed) {
  opacity: 0; transform: scale(0.95);
}
.js-scroll-reveal .revealed {
  opacity: 1 !important; transform: none !important;
}
.fade-in[data-delay="1"], .fade-in-scale[data-delay="1"] { transition-delay: 0.1s; }
.fade-in[data-delay="2"], .fade-in-scale[data-delay="2"] { transition-delay: 0.2s; }
.fade-in[data-delay="3"], .fade-in-scale[data-delay="3"] { transition-delay: 0.3s; }
.fade-in[data-delay="4"], .fade-in-scale[data-delay="4"] { transition-delay: 0.4s; }
.fade-in[data-delay="5"], .fade-in-scale[data-delay="5"] { transition-delay: 0.5s; }
.fade-in[data-delay="6"], .fade-in-scale[data-delay="6"] { transition-delay: 0.6s; }

/* === Navigation === */
.nav {
  position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
  background: transparent;
  transition: background 0.4s var(--ease-smooth), box-shadow 0.4s var(--ease-smooth), backdrop-filter 0.4s var(--ease-smooth);
}
.nav.scrolled {
  background: rgba(10, 10, 10, 0.85);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  box-shadow: 0 1px 0 rgba(255,255,255,0.05);
}
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 72px; max-width: 1400px; margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 40px);
}
.nav-logo {
  font-size: 1.375rem; font-weight: 800; color: var(--text-primary);
  letter-spacing: -0.02em; min-height: auto; min-width: auto;
}
.nav-logo span { color: var(--naver-green); }
.nav-links { display: flex; align-items: center; gap: 32px; }
.nav-links a {
  font-size: 0.9375rem; color: var(--text-secondary); transition: color 0.3s;
  font-weight: 500; min-height: 48px; display: inline-flex; align-items: center;
}
.nav-links a:hover { color: var(--text-primary); }
.nav-buttons { display: flex; align-items: center; gap: 12px; }

/* Buttons */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 12px 24px; border-radius: var(--radius-md); font-size: 0.9375rem;
  font-weight: 600; transition: all 0.3s var(--ease-smooth); min-height: 48px; white-space: nowrap;
}
.btn-naver { background: var(--naver-green); color: #fff; }
.btn-naver:hover {
  background: var(--naver-green-hover);
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 8px 24px var(--naver-green-glow);
}
.btn-naver .naver-logo, .btn-kakao .kakao-logo { width: 18px; height: 18px; flex-shrink: 0; }
.btn-kakao { background: var(--kakao-yellow); color: var(--kakao-text); }
.btn-kakao:hover {
  background: #f0d800;
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 8px 24px rgba(254, 229, 0, 0.15);
}
.btn-outline {
  border: 1px solid var(--border-hover); color: var(--text-secondary); background: transparent;
}
.btn-outline:hover {
  border-color: var(--naver-green); color: var(--naver-green);
  transform: translateY(-2px) scale(1.02);
}
.btn-ghost { color: var(--text-secondary); padding: 12px 16px; }
.btn-ghost:hover { color: var(--text-primary); }
.btn-lg { padding: 16px 32px; font-size: 1.0625rem; border-radius: var(--radius-lg); }

/* Hamburger */
.hamburger {
  display: none; flex-direction: column; gap: 5px; width: 48px; height: 48px;
  align-items: center; justify-content: center; cursor: pointer; z-index: 10;
}
.hamburger span {
  display: block; width: 22px; height: 2px; background: var(--text-primary);
  transition: all 0.3s ease; transform-origin: center;
}
.hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.active span:nth-child(2) { opacity: 0; }
.hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile Menu */
.mobile-menu {
  display: none; position: fixed; top: 72px; left: 0; right: 0; bottom: 0;
  background: rgba(10, 10, 10, 0.98); backdrop-filter: blur(20px);
  z-index: 999; padding: 24px; flex-direction: column; gap: 8px;
}
.mobile-menu.active { display: flex; }
.mobile-menu a {
  display: flex; align-items: center; padding: 16px 20px; font-size: 1.125rem;
  color: var(--text-secondary); border-radius: var(--radius-md); transition: all 0.2s; min-height: 48px;
}
.mobile-menu a:hover { background: var(--bg-card); color: var(--text-primary); }
.mobile-menu .mobile-buttons {
  display: flex; flex-direction: column; gap: 12px; margin-top: 24px;
  padding-top: 24px; border-top: 1px solid var(--border);
}

/* === Hero Section === */
.hero {
  padding: clamp(120px, 15vw, 180px) 0 var(--space-section) 0;
  position: relative; overflow: hidden;
}
.hero-bg-glow {
  position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
  width: 800px; height: 600px;
  background: radial-gradient(ellipse, rgba(3, 199, 90, 0.08) 0%, transparent 70%);
  pointer-events: none; z-index: 0;
}
.hero-content {
  position: relative; z-index: 1; text-align: center; max-width: 800px; margin: 0 auto;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px;
  background: rgba(3, 199, 90, 0.1); border: 1px solid rgba(3, 199, 90, 0.2);
  border-radius: 100px; font-size: var(--fs-small); color: var(--naver-green);
  margin-bottom: 24px; font-weight: 500; min-height: auto;
}
.hero-badge::before {
  content: ''; width: 6px; height: 6px; background: var(--naver-green);
  border-radius: 50%; animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
.hero h1 {
  font-size: var(--fs-display); font-weight: 800; color: var(--text-primary);
  line-height: 1.2; letter-spacing: -0.03em; margin-bottom: 20px;
}
.hero h1 .highlight {
  background: linear-gradient(135deg, var(--naver-green), #0ae67a);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-sub {
  font-size: clamp(1rem, 1.5vw, 1.25rem); color: var(--text-secondary);
  margin-bottom: 36px; line-height: 1.6;
}
.hero-sub span { color: var(--text-primary); font-weight: 500; }
.hero-buttons {
  display: flex; align-items: center; justify-content: center; gap: 16px;
  margin-bottom: 64px; flex-wrap: wrap;
}

/* Dashboard Preview */
.hero-dashboard {
  position: relative; max-width: 960px; margin: 0 auto;
  border-radius: var(--radius-xl); overflow: hidden;
  border: 1px solid var(--border); background: var(--bg-card);
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
}
.hero-dashboard-bar {
  display: flex; align-items: center; gap: 8px; padding: 12px 16px;
  background: var(--bg-elevated); border-bottom: 1px solid var(--border);
}
.hero-dashboard-bar .dot { width: 12px; height: 12px; border-radius: 50%; background: #333; }
.hero-dashboard-bar .dot:nth-child(1) { background: #ff5f57; }
.hero-dashboard-bar .dot:nth-child(2) { background: #febc2e; }
.hero-dashboard-bar .dot:nth-child(3) { background: #28c840; }
.hero-dashboard-body {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 20px;
}
.preview-kpi {
  background: var(--bg-elevated); border-radius: var(--radius-sm);
  padding: 16px; border: 1px solid var(--border);
}
.preview-kpi-label { font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 8px; }
.preview-kpi-value {
  font-size: 1.25rem; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums;
}
.preview-kpi-delta { font-size: 0.75rem; margin-top: 4px; }
.preview-kpi-delta.up { color: var(--naver-green); }
.preview-kpi-delta.down { color: var(--danger); }
.hero-dashboard-charts {
  grid-column: 1 / -1; display: grid; grid-template-columns: 2fr 1fr; gap: 12px;
}
.preview-chart {
  background: var(--bg-elevated); border-radius: var(--radius-sm); padding: 16px;
  border: 1px solid var(--border); height: 180px; display: flex; flex-direction: column;
}
.preview-chart-title { font-size: 0.8125rem; color: var(--text-tertiary); margin-bottom: 12px; }

/* Counter Stats */
.hero-stats {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  max-width: 700px; margin: 48px auto 0;
}
.hero-stat { text-align: center; padding: 20px 8px; }
.hero-stat-value {
  font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: var(--text-primary);
  font-variant-numeric: tabular-nums; line-height: 1.1;
}
.hero-stat-value .counter-suffix { color: var(--naver-green); font-size: 0.7em; }
.hero-stat-label { font-size: var(--fs-small); color: var(--text-tertiary); margin-top: 8px; }

/* === Problem Section === */
.section-problem { padding: var(--space-section) 0; background: var(--bg-primary); }
.section-label {
  display: inline-flex; align-items: center; gap: 8px; font-size: var(--fs-small);
  color: var(--naver-green); font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.05em; margin-bottom: 16px; min-height: auto;
}
.section-title {
  font-size: var(--fs-h2); font-weight: 700; color: var(--text-primary);
  line-height: 1.3; margin-bottom: 12px; letter-spacing: -0.02em;
}
.section-desc {
  font-size: var(--fs-body); color: var(--text-secondary); margin-bottom: 48px; max-width: 600px;
}
.section-header-center { text-align: center; }
.section-header-center .section-desc { margin-left: auto; margin-right: auto; }
.problem-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.problem-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px 24px; transition: all 0.4s var(--ease-smooth); position: relative; overflow: hidden;
}
.problem-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--danger); opacity: 0; transition: opacity 0.3s;
}
.problem-card:hover { border-color: var(--border-hover); transform: translateY(-4px); }
.problem-card:hover::before { opacity: 1; }
.problem-icon {
  width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;
  background: rgba(255, 68, 68, 0.1); border-radius: var(--radius-md); font-size: 1.5rem; margin-bottom: 20px;
}
.problem-card h3 { font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; }
.problem-card p { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.6; }
.problem-stat {
  display: inline-flex; align-items: center; gap: 4px; margin-top: 16px; padding: 6px 12px;
  background: rgba(255, 68, 68, 0.08); border-radius: 100px; font-size: 0.8125rem;
  color: var(--danger); font-weight: 600; min-height: auto;
}

/* === Features Section === */
.section-features { padding: var(--space-section) 0; background: var(--bg-card); position: relative; }
.features-layout { display: grid; grid-template-columns: 320px 1fr; gap: 40px; min-height: 480px; }
.features-tabs { display: flex; flex-direction: column; gap: 4px; }
.feature-tab {
  display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px;
  border-radius: var(--radius-md); cursor: pointer; transition: all 0.3s var(--ease-smooth);
  text-align: left; min-height: 48px; border: 1px solid transparent; background: transparent; width: 100%;
}
.feature-tab:hover { background: var(--bg-elevated); }
.feature-tab.active {
  background: var(--bg-elevated); border-color: var(--naver-green); border-left: 3px solid var(--naver-green);
}
.feature-tab-icon {
  width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
  background: rgba(3, 199, 90, 0.1); border-radius: var(--radius-sm); font-size: 1.25rem; flex-shrink: 0;
}
.feature-tab.active .feature-tab-icon { background: var(--naver-green); }
.feature-tab-text h4 { font-size: 0.9375rem; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
.feature-tab-text p { font-size: 0.8125rem; color: var(--text-tertiary); display: none; }
.feature-tab.active .feature-tab-text p { display: block; }
.features-content {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 40px; display: flex; flex-direction: column; justify-content: center;
}
.feature-panel { display: none; }
.feature-panel.active { display: block; }
.feature-panel h3 { font-size: var(--fs-h3); font-weight: 700; color: var(--text-primary); margin-bottom: 16px; }
.feature-panel p { font-size: var(--fs-body); color: var(--text-secondary); line-height: 1.7; margin-bottom: 24px; }
.feature-highlights { display: flex; flex-direction: column; gap: 12px; }
.feature-highlight {
  display: flex; align-items: flex-start; gap: 12px; padding: 12px 16px;
  background: rgba(3, 199, 90, 0.05); border-radius: var(--radius-sm);
  border: 1px solid rgba(3, 199, 90, 0.08);
}
.feature-highlight-icon {
  color: var(--naver-green); font-size: 1.125rem; flex-shrink: 0; margin-top: 2px;
  min-height: auto; min-width: auto;
}
.feature-highlight-text { font-size: var(--fs-small); color: var(--text-secondary); line-height: 1.5; }
.feature-highlight-text strong { color: var(--text-primary); }

/* === Comparison Table === */
.section-compare { padding: var(--space-section) 0; background: var(--bg-primary); }
.compare-table-wrap {
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  border-radius: var(--radius-lg); border: 1px solid var(--border);
}
.compare-table { width: 100%; min-width: 700px; border-collapse: collapse; font-size: var(--fs-body); }
.compare-table th, .compare-table td {
  padding: 16px 20px; text-align: center; border-bottom: 1px solid var(--border);
}
.compare-table th {
  background: var(--bg-elevated); font-weight: 600; color: var(--text-secondary);
  font-size: var(--fs-small); text-transform: uppercase; letter-spacing: 0.03em;
}
.compare-table th:first-child { text-align: left; }
.compare-table td:first-child { text-align: left; font-weight: 500; color: var(--text-primary); }
.compare-table td { color: var(--text-secondary); }
.compare-table tr:last-child td { border-bottom: 0; }
.compare-table .col-onda {
  background: rgba(3, 199, 90, 0.08); color: var(--text-primary); font-weight: 600;
}
.compare-table .col-onda-header {
  background: rgba(3, 199, 90, 0.15); color: var(--naver-green); font-weight: 700; font-size: 0.9375rem;
}
.compare-table tr:hover td { background: rgba(255,255,255,0.02); }
.compare-table tr:hover .col-onda { background: rgba(3, 199, 90, 0.12); }

/* === Points Section === */
.section-points { padding: var(--space-section) 0; background: var(--bg-card); }
.points-tiers { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
.tier-card {
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-lg);
  padding: 32px 24px; text-align: center; transition: all 0.4s var(--ease-smooth); position: relative;
}
.tier-card:hover { border-color: var(--naver-green); transform: translateY(-4px); }
.tier-card.featured { border-color: var(--naver-green); background: rgba(3, 199, 90, 0.05); }
.tier-card.featured::before {
  content: '인기'; position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  background: var(--naver-green); color: #fff; font-size: 0.75rem; font-weight: 700;
  padding: 4px 16px; border-radius: 100px;
}
.tier-range { font-size: var(--fs-small); color: var(--text-tertiary); margin-bottom: 12px; }
.tier-rate { font-size: 3rem; font-weight: 800; color: var(--naver-green); line-height: 1; margin-bottom: 4px; }
.tier-rate span { font-size: 1.5rem; }
.tier-example {
  font-size: var(--fs-small); color: var(--text-secondary); margin-top: 12px;
  padding-top: 12px; border-top: 1px solid var(--border);
}
.tier-example strong { color: var(--text-primary); }

/* Points Usage */
.points-usage {
  display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 48px; justify-content: center;
}
.points-usage-tag {
  display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px;
  background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 100px;
  font-size: var(--fs-small); color: var(--text-secondary); min-height: auto;
}
.points-usage-tag::before { content: '✓'; color: var(--naver-green); font-weight: 700; }

/* Calculator */
.calculator-wrap {
  max-width: 500px; margin: 0 auto; background: var(--bg-elevated);
  border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px;
}
.calculator-title {
  font-size: 1.125rem; font-weight: 700; color: var(--text-primary);
  margin-bottom: 24px; text-align: center;
}
.calculator-input-group { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.calculator-input {
  flex: 1; padding: 14px 16px; background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-md); color: var(--text-primary); font-size: 1rem; font-weight: 600;
  min-height: 48px; transition: border-color 0.3s;
}
.calculator-input:focus { outline: none; border-color: var(--naver-green); }
.calculator-input::placeholder { color: var(--text-tertiary); }
.calculator-suffix { font-size: var(--fs-body); color: var(--text-tertiary); white-space: nowrap; }
.calculator-result {
  text-align: center; padding: 20px;
  background: rgba(3, 199, 90, 0.08); border: 1px solid rgba(3, 199, 90, 0.15); border-radius: var(--radius-md);
}
.calculator-result-label { font-size: var(--fs-small); color: var(--text-secondary); margin-bottom: 8px; }
.calculator-result-value { font-size: 2rem; font-weight: 800; color: var(--naver-green); }
.calculator-result-note { font-size: 0.75rem; color: var(--text-tertiary); margin-top: 8px; }

/* === Homepage Packages === */
.section-packages { padding: var(--space-section) 0; background: var(--bg-primary); }
.packages-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
.package-card {
  background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);
