<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>🎲 팝업스토어 부루마블</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0D0D1A;--card:rgba(255,255,255,0.06);--border:rgba(255,255,255,0.1);
  --orange:#FF6B35;--cyan:#00D4FF;--gold:#FFD700;
  --text:#E8E8F0;--sub:#9999AA;--radius:12px;
}
body{
  font-family:'Pretendard Variable',Pretendard,-apple-system,sans-serif;
  background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);
  background-size:40px 40px;
}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at center,transparent 50%,rgba(0,0,0,0.4));pointer-events:none;z-index:0}
h1,h2,h3{font-family:'Black Han Sans',sans-serif;word-break:keep-all}
#app{position:relative;z-index:1;max-width:800px;margin:0 auto;padding:16px;min-height:100vh;display:flex;flex-direction:column}
header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
header h1{font-size:26px;background:linear-gradient(135deg,var(--orange),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px}
.hdr-btns{display:flex;gap:8px}
.btn{
  background:var(--card);border:1px solid var(--border);color:var(--text);
  padding:8px 14px;border-radius:8px;cursor:pointer;font-family:inherit;font-size:13px;
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);transition:all .2s;
}
.btn:hover{background:rgba(255,255,255,0.12);transform:scale(1.05)}
.btn:active{transform:scale(.97)}

/* ===== BOARD ===== */
#board{
  display:grid;grid-template-columns:repeat(6,1fr);grid-template-rows:repeat(6,1fr);
  gap:5px;flex:1;max-width:720px;width:100%;margin:0 auto;aspect-ratio:1;
}
.cell{
  background:var(--card);border:1px solid var(--border);border-radius:var(--radius);
  backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
  padding:4px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  position:relative;overflow:hidden;cursor:default;
  animation:cellIn .4s ease both;transition:box-shadow .3s,border-color .3s,transform .3s;
}
.cell .em{font-size:20px;line-height:1.2}
.cell .nm{font-size:9px;margin-top:1px;opacity:.65;text-align:center;word-break:keep-all;line-height:1.15}
.cell .pl{
  position:absolute;bottom:2px;right:3px;font-size:15px;
  animation:pulse 1s ease infinite;filter:drop-shadow(0 0 6px var(--cyan));
}
.cell.active{border-color:var(--cyan);box-shadow:0 0 20px rgba(0,212,255,.4),0 0 40px rgba(0,212,255,.15);transform:scale(1.06);z-index:2}
.cell.start{border-color:var(--orange);background:rgba(255,107,53,.08)}
.cell.island{border-color:#ff4444;background:rgba(255,68,68,.06)}
.cell.chance{border-color:#aa66ff;background:rgba(170,102,255,.06)}
.cell.lucky{border-color:var(--gold);background:rgba(255,215,0,.06)}
.cell.back{border-color:#ff6b6b;background:rgba(255,107,107,.05)}
.cell.forward{border-color:#66ff88;background:rgba(102,255,136,.05)}
.cell.extra{border-color:var(--gold);background:rgba(255,215,0,.05)}
@keyframes cellIn{from{opacity:0;transform:scale(.7) translateY(10px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.25)}}

/* Grid positions */
.cell[data-i="0"]{grid-row:1;grid-column:1}
.cell[data-i="1"]{grid-row:1;grid-column:2}
.cell[data-i="2"]{grid-row:1;grid-column:3}
.cell[data-i="3"]{grid-row:1;grid-column:4}
.cell[data-i="4"]{grid-row:1;grid-column:5}
.cell[data-i="5"]{grid-row:1;grid-column:6}
.cell[data-i="6"]{grid-row:2;grid-column:6}
.cell[data-i="7"]{grid-row:3;grid-column:6}
.cell[data-i="8"]{grid-row:4;grid-column:6}
.cell[data-i="9"]{grid-row:5;grid-column:6}
.cell[data-i="10"]{grid-row:6;grid-column:6}
.cell[data-i="11"]{grid-row:6;grid-column:5}
.cell[data-i="12"]{grid-row:6;grid-column:4}
.cell[data-i="13"]{grid-row:6;grid-column:3}
.cell[data-i="14"]{grid-row:6;grid-column:2}
.cell[data-i="15"]{grid-row:6;grid-column:1}
.cell[data-i="16"]{grid-row:5;grid-column:1}
.cell[data-i="17"]{grid-row:4;grid-column:1}
.cell[data-i="18"]{grid-row:3;grid-column:1}
.cell[data-i="19"]{grid-row:2;grid-column:1}

/* ===== CENTER ===== */
#center{
  grid-row:2/6;grid-column:2/6;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:12px;
}
.dice-scene{width:80px;height:80px;perspective:300px;margin:0 auto}
.dice-cube{
  width:80px;height:80px;position:relative;
  transform-style:preserve-3d;transition:transform .5s cubic-bezier(.2,.8,.3,1);
}
.face{
  position:absolute;width:80px;height:80px;background:#fff;border-radius:10px;
  display:grid;grid-template:repeat(3,1fr)/repeat(3,1fr);padding:10px;
  box-shadow:inset 0 0 6px rgba(0,0,0,.06);
}
.face.f{transform:translateZ(40px)}.face.bk{transform:rotateY(180deg) translateZ(40px)}
.face.r{transform:rotateY(90deg) translateZ(40px)}.face.l{transform:rotateY(-90deg) translateZ(40px)}
.face.t{transform:rotateX(90deg) translateZ(40px)}.face.bt{transform:rotateX(-90deg) translateZ(40px)}
.dot{width:100%;aspect-ratio:1;background:#1a1a2e;border-radius:50%;place-self:center;max-width:15px}
.dot-x{visibility:hidden}
#dice-result{font-family:'Black Han Sans';font-size:22px;color:var(--gold);min-height:28px;text-align:center}
#roll-btn{
  background:linear-gradient(135deg,var(--orange),#ff8f5e);border:none;color:#fff;
  padding:12px 28px;border-radius:var(--radius);font-family:inherit;font-size:15px;font-weight:700;
  cursor:pointer;box-shadow:0 0 20px rgba(255,107,53,.4);transition:all .2s;word-break:keep-all;
}
#roll-btn:hover{transform:scale(1.08);box-shadow:0 0 30px rgba(255,107,53,.6)}
#roll-btn:active{transform:scale(.95)}
#roll-btn:disabled{opacity:.45;cursor:not-allowed;transform:none;box-shadow:none}
#info{text-align:center;font-size:12px;color:var(--sub);line-height:1.6}
#info span{color:var(--cyan);font-weight:600}

/* ===== MODAL ===== */
.modal{
  position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;z-index:1000;
  opacity:0;pointer-events:none;transition:opacity .3s;
}
.modal.show{opacity:1;pointer-events:all}
.modal-box{
  background:rgba(18,18,38,.96);border:1px solid var(--border);border-radius:20px;
  padding:32px;text-align:center;max-width:340px;width:90%;
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  transform:scale(.8) translateY(20px);transition:transform .4s cubic-bezier(.34,1.56,.64,1);
}
.modal.show .modal-box{transform:scale(1) translateY(0)}
.modal-box .m-em{font-size:48px;margin-bottom:10px}
.modal-box h2{font-size:20px;margin-bottom:6px}
.modal-box p{color:var(--sub);margin-bottom:18px;font-size:14px;word-break:keep-all;line-height:1.5}
.btn-ok{
  background:linear-gradient(135deg,var(--cyan),#0099cc);border:none;color:#fff;
  padding:11px 26px;border-radius:10px;font-size:14px;font-weight:600;
  cursor:pointer;font-family:inherit;transition:all .2s;
}
.btn-ok:hover{transform:scale(1.06)}
.modal-box.win h2{
  font-size:26px;background:linear-gradient(135deg,var(--gold),var(--orange));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
#confetti{position:fixed;inset:0;z-index:999;pointer-events:none}

/* ===== TABLET ===== */
@media(max-width:1023px){
  #app{padding:10px}
  header h1{font-size:22px}
  .cell .em{font-size:17px}.cell .nm{font-size:8px}
  .dice-scene,.dice-cube{width:64px;height:64px}
  .face{width:64px;height:64px;padding:8px}
  .face.f{transform:translateZ(32px)}.face.bk{transform:rotateY(180deg) translateZ(32px)}
  .face.r{transform:rotateY(90deg) translateZ(32px)}.face.l{transform:rotateY(-90deg) translateZ(32px)}
  .face.t{transform:rotateX(90deg) translateZ(32px)}.face.bt{transform:rotateX(-90deg) translateZ(32px)}
  .dot{max-width:12px}
  #roll-btn{padding:10px 22px;font-size:14px}
}

/* ===== MOBILE ===== */
@media(max-width:767px){
  #board{
    display:flex;flex-direction:column;gap:6px;
    aspect-ratio:auto;max-height:none;padding-bottom:160px;overflow-y:auto;
  }
  .cell{flex-direction:row;gap:10px;padding:10px 14px;justify-content:flex-start;min-height:48px}
  .cell .em{font-size:22px}.cell .nm{font-size:13px;margin-top:0}
  .cell .pl{position:static;margin-left:auto}
  .cell.active{transform:none;box-shadow:0 0 14px rgba(0,212,255,.4)}
  #center{
    position:fixed;bottom:0;left:0;right:0;
    background:rgba(13,13,26,.96);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
    border-top:1px solid var(--border);padding:10px 16px;
    flex-direction:row;gap:12px;z-index:100;
    grid-row:auto;grid-column:auto;
  }
  .dice-scene,.dice-cube{width:52px;height:52px}
  .face{width:52px;height:52px;padding:6px}
  .face.f{transform:translateZ(26px)}.face.bk{transform:rotateY(180deg) translateZ(26px)}
  .face.r{transform:rotateY(90deg) translateZ(26px)}.face.l{transform:rotateY(-90deg) translateZ(26px)}
  .face.t{transform:rotateX(90deg) translateZ(26px)}.face.bt{transform:rotateX(-90deg) translateZ(26px)}
  .dot{max-width:10px}
  #dice-result{font-size:16px;min-height:20px}
  #info{font-size:10px;line-height:1.3}
  #roll-btn{padding:10px 18px;font-size:13px;white-space:nowrap}
}
</style>
</head>
<body>
<div id="app">
  <header>
    <h1>🎲 부루마블</h1>
    <div class="hdr-btns">
      <button class="btn" id="snd-btn" title="사운드">🔊</button>
      <button class="btn" id="rst-btn">다시하기</button>
    </div>
  </header>
  <div id="board"></div>
  <div class="modal" id="ev-modal">
    <div class="modal-box">
      <div class="m-em" id="me"></div>
      <h2 id="mt"></h2>
      <p id="md"></p>
      <button class="btn-ok" id="mc">확인</button>
    </div>
  </div>
  <div class="modal" id="win-modal">
    <div class="modal-box win">
      <div class="m-em">🎉</div>
      <h2>완주 축하!</h2>
      <p>한 바퀴를 완주했습니다!<br>대단해요!</p>
      <button class="btn-ok" id="wc">다시하기</button>
    </div>
  </div>
  <canvas id="confetti"></canvas>
</div>
<script>
const C=[
  {n:'출발 START',e:'🚀',t:'start'},{n:'커피숍',e:'☕',t:'normal'},
  {n:'찬스카드',e:'🎴',t:'chance'},{n:'포토존',e:'📸',t:'normal'},
  {n:'무인도',e:'🏝️',t:'island'},{n:'팝업A',e:'🛍️',t:'normal'},
  {n:'행운주사위',e:'🎲',t:'extra'},{n:'푸드트럭',e:'🍔',t:'normal'},
  {n:'뒤로2칸',e:'⬅️',t:'back'},{n:'포토존B',e:'📸',t:'normal'},
  {n:'무료주차',e:'🅿️',t:'normal'},{n:'DJ부스',e:'🎵',t:'normal'},
  {n:'찬스카드',e:'🎴',t:'chance'},{n:'네일아트',e:'💅',t:'normal'},
  {n:'무인도',e:'🏝️',t:'island'},{n:'팝업B',e:'🛍️',t:'normal'},
  {n:'앞으로3칸',e:'➡️',t:'forward'},{n:'플리마켓',e:'🧺',t:'normal'},
  {n:'포토존C',e:'📸',t:'normal'},{n:'럭키박스',e:'🎁',t:'lucky'}
];
const CH=[
  {x:'앞으로 1칸 전진!',a:'mv',v:1},{x:'뒤로 1칸 후퇴!',a:'mv',v:-1},
  {x:'출발점으로 순간이동!',a:'go',v:0},{x:'1턴 쉬기!',a:'sk'},
  {x:'행운의 찬스! 한번 더!',a:'ex'}
];
const LK=[
  {x:'황금 열쇠! 앞으로 2칸!',a:'mv',v:2},
  {x:'보물 발견! 한번 더!',a:'ex'},
  {x:'빈 상자... 아무 일도 없었다.',a:'no'}
];
const DP={1:[[2,2]],2:[[1,3],[3,1]],3:[[1,3],[2,2],[3,1]],
  4:[[1,1],[1,3],[3,1],[3,3]],5:[[1,1],[1,3],[2,2],[3,1],[3,3]],
  6:[[1,1],[1,3],[2,1],[2,3],[3,1],[3,3]]};
const ROTS={1:'rotateX(0) rotateY(0)',2:'rotateY(-90deg)',3:'rotateX(-90deg)',
  4:'rotateX(90deg)',5:'rotateY(90deg)',6:'rotateY(180deg)'};

class Game{
  constructor(){
    this.pos=0;this.skip=false;this.busy=false;this.left=false;this.won=false;
    this.snd=true;this.ctx=null;
    this.bd=document.getElementById('board');
    this.build();this.bind();this.upd();
  }
  build(){
    for(let i=0;i<20;i++){
      const d=document.createElement('div');
      d.className='cell '+C[i].t;d.dataset.i=i;
      d.style.animationDelay=i*.04+'s';
      d.innerHTML=`<span class="em">${C[i].e}</span><span class="nm">${C[i].n}</span>`;
      this.bd.appendChild(d);
    }
    const cn=document.createElement('div');cn.id='center';
    const sc=document.createElement('div');sc.className='dice-scene';
    const cu=document.createElement('div');cu.className='dice-cube';cu.id='dice';
    const fs=['f','bk','r','l','t','bt'],fn=[1,6,2,5,3,4];
    fs.forEach((f,idx)=>{
      const fc=document.createElement('div');fc.className='face '+f;
      for(let r=1;r<=3;r++)for(let c=1;c<=3;c++){
        const dd=document.createElement('div');
        dd.className=DP[fn[idx]].some(p=>p[0]===r&&p[1]===c)?'dot':'dot-x';
        dd.style.gridRow=r;dd.style.gridColumn=c;fc.appendChild(dd);
      }
      cu.appendChild(fc);
    });
    sc.appendChild(cu);
    const rs=document.createElement('div');rs.id='dice-result';
    const bt=document.createElement('button');bt.id='roll-btn';bt.textContent='🎲 주사위 굴리기';
    const inf=document.createElement('div');inf.id='info';
    inf.innerHTML='현재: <span id="pt">출발</span> · 진행: <span id="pg">0/20</span>';
    cn.append(sc,rs,bt,inf);
    this.bd.appendChild(cn);
    this.dice=cu;this.rbtn=bt;this.rres=rs;
  }
  bind(){
    this.rbtn.onclick=()=>this.turn();
    document.getElementById('mc').onclick=()=>{
      document.getElementById('ev-modal').classList.remove('show');
      if(this._cb){const f=this._cb;this._cb=null;f();}
    };
    document.getElementById('rst-btn').onclick=()=>this.reset();
    document.getElementById('wc').onclick=()=>{document.getElementById('win-modal').classList.remove('show');this.reset();};
    document.getElementById('snd-btn').onclick=()=>{
      this.snd=!this.snd;document.getElementById('snd-btn').textContent=this.snd?'🔊':'🔇';
    };
  }
  async turn(){
    if(this.busy||this.won)return;
    this.busy=true;this.rbtn.disabled=true;
    if(this.skip){
      this.skip=false;this.sfx('ev');
      await this.mdl('🏝️','무인도!','이번 턴은 쉬어갑니다...');
      this.busy=false;this.rbtn.disabled=false;return;
    }
    const v=await this.roll();
    this.rres.textContent='🎯 '+v;
    await this.move(v);
    if(!this.won)await this.evt();
    if(!this.won){this.busy=false;this.rbtn.disabled=false;}
  }
  roll(){
    return new Promise(ok=>{
      const r=Math.floor(Math.random()*6)+1;this.sfx('rl');
      let c=0;
      const si=setInterval(()=>{
        this.dice.style.transition='none';
        this.dice.style.transform=`rotateX(${Math.random()*720-360}deg) rotateY(${Math.random()*720-360}deg)`;
        if(++c>=12){
          clearInterval(si);
          this.dice.style.transition='transform .5s cubic-bezier(.2,.8,.3,1)';
          this.dice.style.transform=ROTS[r];
          setTimeout(()=>ok(r),550);
        }
      },75);
    });
  }
  async move(s){
    for(let i=0;i<s;i++){
      this.pos=(this.pos+1)%20;
      if(this.pos!==0)this.left=true;
      this.upd();this.sfx('st');
      await this.w(180);
      if(this.pos===0&&this.left){await this.winGame();return;}
    }
  }
  async evt(){
    const c=C[this.pos];
    if(c.t==='normal'||c.t==='start')return;
    this.sfx('ev');
    if(c.t==='island'){
      this.skip=true;
      await this.mdl('🏝️','무인도에 도착!','다음 턴을 쉬어야 합니다.');
    }else if(c.t==='back'){
      await this.mdl('⬅️','뒤로 2칸!','앗, 뒤로 돌아갑니다!');
      this.pos=(this.pos-2+20)%20;this.upd();this.sfx('st');
    }else if(c.t==='forward'){
      await this.mdl('➡️','앞으로 3칸!','신나게 달려갑니다!');
      for(let i=0;i<3;i++){
        this.pos=(this.pos+1)%20;
        if(this.pos!==0)this.left=true;
        this.upd();this.sfx('st');await this.w(180);
        if(this.pos===0&&this.left){await this.winGame();return;}
      }
    }else if(c.t==='extra'){
      await this.mdl('🎲','행운의 주사위!','한 번 더 굴릴 수 있습니다!');
      this.busy=false;this.rbtn.disabled=false;
    }else if(c.t==='chance'){
      const ch=CH[Math.floor(Math.random()*CH.length)];
      await this.mdl('🎴','찬스 카드!',ch.x);
      await this.apply(ch);
    }else if(c.t==='lucky'){
      const lk=LK[Math.floor(Math.random()*LK.length)];
      await this.mdl('🎁','럭키 박스!',lk.x);
      await this.apply(lk);
    }
  }
  async apply(ch){
    if(ch.a==='mv'){
      if(ch.v>0){
        for(let i=0;i<ch.v;i++){
          this.pos=(this.pos+1)%20;
          if(this.pos!==0)this.left=true;
          this.upd();this.sfx('st');await this.w(180);
          if(this.pos===0&&this.left){await this.winGame();return;}
        }
      }else{this.pos=(this.pos+ch.v+20)%20;this.upd();}
    }else if(ch.a==='go'){this.pos=ch.v;this.upd();}
    else if(ch.a==='sk'){this.skip=true;}
    else if(ch.a==='ex'){this.busy=false;this.rbtn.disabled=false;}
  }
  async winGame(){
    this.won=true;this.sfx('wn');this.confetti();
    document.getElementById('win-modal').classList.add('show');
  }
  mdl(em,ti,de){
    document.getElementById('me').textContent=em;
    document.getElementById('mt').textContent=ti;
    document.getElementById('md').textContent=de;
    document.getElementById('ev-modal').classList.add('show');
    return new Promise(r=>{this._cb=r;});
  }
  upd(){
    document.querySelectorAll('.cell').forEach(el=>{
      const i=+el.dataset.i,act=i===this.pos;
      el.classList.toggle('active',act);
      const p=el.querySelector('.pl');if(p)p.remove();
      if(act){
        const s=document.createElement('span');s.className='pl';s.textContent='🏃';
        el.appendChild(s);
        if(window.innerWidth<=767)el.scrollIntoView({behavior:'smooth',block:'center'});
      }
    });
    const pt=document.getElementById('pt'),pg=document.getElementById('pg');
    if(pt)pt.textContent=C[this.pos].n;
    if(pg)pg.textContent=this.pos+'/20';
  }
  reset(){
    this.pos=0;this.skip=false;this.busy=false;this.left=false;this.won=false;
    this.rres.textContent='';this.rbtn.disabled=false;
    document.getElementById('win-modal').classList.remove('show');
    document.getElementById('ev-modal').classList.remove('show');
    this.upd();this.stopCf();
  }
  w(ms){return new Promise(r=>setTimeout(r,ms));}

  /* Audio */
  ac(){if(!this.ctx)this.ctx=new(window.AudioContext||window.webkitAudioContext)();return this.ctx;}
  tone(f,d,tp='sine',vol=.12){
    if(!this.snd)return;const c=this.ac(),o=c.createOscillator(),g=c.createGain();
    o.type=tp;o.frequency.value=f;g.gain.value=vol;
    g.gain.exponentialRampToValueAtTime(.001,c.currentTime+d);
    o.connect(g);g.connect(c.destination);o.start(c.currentTime);o.stop(c.currentTime+d);
  }
  sfx(t){
    if(!this.snd)return;
    if(t==='rl')for(let i=0;i<5;i++)setTimeout(()=>this.tone(200+i*80,.08,'triangle',.08),i*55);
    else if(t==='st')this.tone(600,.07,'sine',.08);
    else if(t==='ev'){this.tone(523,.12,'sine',.1);setTimeout(()=>this.tone(659,.12,'sine',.1),90);}
    else if(t==='wn')[523,659,784,1047].forEach((f,i)=>setTimeout(()=>this.tone(f,.3,'sine',.12),i*140));
  }

  /* Confetti */
  confetti(){
    const cv=document.getElementById('confetti');
    cv.width=window.innerWidth;cv.height=window.innerHeight;
    const cx=cv.getContext('2d');
    const cols=['#FF6B35','#00D4FF','#FFD700','#ff4444','#66ff88','#aa66ff','#FF4081'];
    const ps=Array.from({length:150},()=>({
      x:Math.random()*cv.width,y:Math.random()*cv.height-cv.height,
      vx:(Math.random()-.5)*5,vy:Math.random()*3+2,
      s:Math.random()*8+3,c:cols[Math.floor(Math.random()*cols.length)],
      r:Math.random()*360,rv:(Math.random()-.5)*10
    }));
    this._cf=true;
    const draw=()=>{
      if(!this._cf)return;
      cx.clearRect(0,0,cv.width,cv.height);
      ps.forEach(p=>{
        p.x+=p.vx;p.y+=p.vy;p.r+=p.rv;p.vy+=.04;
        if(p.y>cv.height){p.y=-10;p.x=Math.random()*cv.width;p.vy=Math.random()*3+2;}
        cx.save();cx.translate(p.x,p.y);cx.rotate(p.r*Math.PI/180);
        cx.fillStyle=p.c;cx.fillRect(-p.s/2,-p.s/2,p.s,p.s*.6);cx.restore();
      });
      requestAnimationFrame(draw);
    };draw();
  }
  stopCf(){
    this._cf=false;
    const cv=document.getElementById('confetti');
    cv.getContext('2d').clearRect(0,0,cv.width,cv.height);
  }
}
window.addEventListener('DOMContentLoaded',()=>new Game());
</script>
</body>
</html>
