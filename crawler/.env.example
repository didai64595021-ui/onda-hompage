# ─── 네이버 API (필수) ───
NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# ─── SMS 발송 (CoolSMS) ───
COOLSMS_API_KEY=your_api_key
COOLSMS_API_SECRET=your_api_secret
COOLSMS_SENDER=01012345678

# ─── 이메일 발송 (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your@gmail.com

# ─── 카카오 알림톡 ───
KAKAO_ALIMTALK_KEY=your_key
KAKAO_SENDER_KEY=your_sender_key
KAKAO_TEMPLATE_CODE=your_template

# ─── 발송 설정 ───
SEND_SMS_DELAY=3000
SEND_EMAIL_DELAY=5000
SEND_BATCH_LIMIT=100
